generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum UserRole {
  PLATFORM_ADMIN
  BUSINESS_OWNER
  BUSINESS_MANAGER
  STAFF_MEMBER
  RECEPTIONIST
  CLIENT
}

enum BusinessPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum AppointmentStatus {
  PENDING_PAYMENT
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
  IN_PROCESS
}

enum PaymentMode {
  DISABLED
  FULL
  PERCENTAGE
  FIXED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum BlockType {
  FULL_DAY
  PARTIAL
}

enum OverrideType {
  BLOCKED
  AVAILABLE
}

// ──────────────────────────────────────────
// Auth (NextAuth v5 / Prisma Adapter)
// ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────
// User
// ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  phone          String?
  role           UserRole  @default(CLIENT)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  businesses    UserBusiness[]
  staffProfile  StaffMember?
  appointments  Appointment[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([email])
}

// ──────────────────────────────────────────
// Multi-Tenant: Business
// ──────────────────────────────────────────

model Business {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  description  String?      @db.Text
  logo         String?
  coverImage   String?
  address      String?
  city         String?
  province     String?
  phone        String?
  whatsapp     String?
  email        String?
  website      String?
  primaryColor String       @default("#6366F1")
  accentColor  String       @default("#22D3EE")
  plan         BusinessPlan @default(FREE)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  settings     BusinessSettings?
  config       BusinessConfig[]
  members      UserBusiness[]
  staff        StaffMember[]
  categories   ServiceCategory[]
  services     Service[]
  appointments Appointment[]
  payments     Payment[]
  notifications Notification[]
  auditLogs    AuditLog[]
  guestClients GuestClient[]

  @@index([slug])
}

// Junction: User <-> Business (multi-business support)
model UserBusiness {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       UserRole @default(CLIENT)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

// ──────────────────────────────────────────
// Business Settings & Config
// ──────────────────────────────────────────

model BusinessSettings {
  id                 String      @id @default(cuid())
  businessId         String      @unique
  slotInterval       Int         @default(30)
  minAdvanceHours    Int         @default(2)
  maxAdvanceDays     Int         @default(30)
  bufferMinutes      Int         @default(0)
  allowGuestBooking  Boolean     @default(true)
  requireDeposit     Boolean     @default(false)
  paymentMode        PaymentMode @default(DISABLED)
  depositPercentage  Float?
  depositFixedAmount Float?
  cancellationPolicy String?     @db.Text
  timezone           String      @default("America/Argentina/Buenos_Aires")
  currency           String      @default("ARS")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// Key-value config (MP tokens, Twilio keys, etc.)
model BusinessConfig {
  id         String   @id @default(cuid())
  businessId String
  key        String
  value      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, key])
  @@index([businessId])
}

// ──────────────────────────────────────────
// Staff
// ──────────────────────────────────────────

model StaffMember {
  id          String   @id @default(cuid())
  businessId  String
  userId      String?  @unique
  name        String
  email       String?
  phone       String?
  image       String?
  bio         String?  @db.Text
  specialty   String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  services      StaffService[]
  workingHours  WorkingHours[]
  blockedDates  BlockedDate[]
  recurringBlocks RecurringBlockedSlot[]
  dateOverrides DateSlotOverride[]
  appointments  Appointment[]

  @@index([businessId])
}

// Junction: Staff <-> Service
model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([serviceId])
}

// ──────────────────────────────────────────
// Services
// ──────────────────────────────────────────

model ServiceCategory {
  id         String   @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([businessId])
}

model Service {
  id          String   @id @default(cuid())
  businessId  String
  categoryId  String?
  name        String
  description String?  @db.Text
  duration    Int      // minutes
  price       Float
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  staff        StaffService[]
  appointments Appointment[]

  @@index([businessId])
  @@index([categoryId])
}

// ──────────────────────────────────────────
// Schedule
// ──────────────────────────────────────────

model WorkingHours {
  id        String  @id @default(cuid())
  staffId   String
  dayOfWeek Int     // 0=Sunday, 6=Saturday
  startTime String  // "HH:mm"
  endTime   String  // "HH:mm"
  isActive  Boolean @default(true)

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
}

model BlockedDate {
  id        String    @id @default(cuid())
  staffId   String
  date      DateTime
  type      BlockType @default(FULL_DAY)
  startTime String?   // "HH:mm" for PARTIAL
  endTime   String?   // "HH:mm" for PARTIAL
  reason    String?
  createdAt DateTime  @default(now())

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, date])
}

model RecurringBlockedSlot {
  id        String @id @default(cuid())
  staffId   String
  dayOfWeek Int    // 0-6
  time      String // "HH:mm"

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek, time])
  @@index([staffId])
}

model DateSlotOverride {
  id   String       @id @default(cuid())
  staffId String
  date DateTime
  time String       // "HH:mm"
  type OverrideType

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date, time])
  @@index([staffId, date])
}

// ──────────────────────────────────────────
// Appointments
// ──────────────────────────────────────────

model Appointment {
  id            String            @id @default(cuid())
  businessId    String
  serviceId     String
  staffId       String
  userId        String?
  guestClientId String?
  dateTime      DateTime
  endTime       DateTime
  status        AppointmentStatus @default(PENDING)
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service     Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff       StaffMember  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestClient GuestClient? @relation(fields: [guestClientId], references: [id], onDelete: SetNull)
  payment     Payment?
  notifications Notification[]

  @@index([businessId, dateTime])
  @@index([staffId, dateTime])
  @@index([userId])
  @@index([status])
}

// ──────────────────────────────────────────
// Guest Clients (non-registered)
// ──────────────────────────────────────────

model GuestClient {
  id         String   @id @default(cuid())
  businessId String
  name       String
  phone      String
  email      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([businessId, phone])
  @@index([businessId])
}

// ──────────────────────────────────────────
// Payments
// ──────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  businessId      String
  appointmentId   String        @unique
  amount          Float
  mode            PaymentMode
  status          PaymentStatus @default(PENDING)
  mpPreferenceId  String?
  mpPaymentId     String?
  mpStatus        String?
  externalReference String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([mpPreferenceId])
}

// ──────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────

model Notification {
  id            String              @id @default(cuid())
  businessId    String
  appointmentId String?
  userId        String?
  channel       NotificationChannel
  type          String              // confirmation, reminder, cancellation
  status        NotificationStatus  @default(PENDING)
  recipient     String
  error         String?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([appointmentId])
}

// ──────────────────────────────────────────
// Audit Log
// ──────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  businessId String?
  userId     String?
  action     String   // create, update, delete
  entity     String   // appointment, service, etc.
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([entity, createdAt])
  @@index([userId])
}
